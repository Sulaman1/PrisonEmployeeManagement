<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Prison Employee Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        html, body {
            height: 100%;
        }
        
        body {
            display: flex;
            flex-direction: column;
            background-color: #f8f9fa;
        }
        
        .navbar-brand {
            font-weight: bold;
        }
        
        .btn {
            margin: 2px;
        }
        
        .card {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            margin-bottom: 20px;
        }
        
        main {
            flex: 1 0 auto;
        }
        
        .footer {
            flex-shrink: 0;
            background-color: #343a40 !important;
        }
        
        .container-fluid {
            padding: 20px;
        }
        
        /* Table styles */
        .table-responsive {
            margin-top: 20px;
        }
        
        .table th {
            background-color: #343a40;
            color: white;
        }
        
        /* Alert styles */
        .alert {
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Employees" asp-action="Index">
                <i class="fas fa-prison"></i> Prison Employee Management
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Employees" asp-action="Index">
                            <i class="fas fa-users"></i> Employees
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Employees" asp-action="Create">
                            <i class="fas fa-plus"></i> Add Employee
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="EFiles" asp-action="Index">
                            <i class="fas fa-folder-open"></i> EFiling
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="workflowDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-tasks"></i> Workflow
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Workflow" asp-action="Dashboard">Dashboard</a></li>
                            <li><a class="dropdown-item" asp-controller="Workflow" asp-action="Inbox">Inbox</a></li>
                            <li><a class="dropdown-item" asp-controller="Workflow" asp-action="Sent">Sent Items</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    
    <main>
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>
    
    <footer class="footer bg-dark text-white py-3">
        <div class="container text-center">
            <span>&copy; 2026 - Prison Employee Management System. All rights reserved.</span>
        </div>
    </footer>
    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>