@model PrisonEmployeeManagement.Models.FileWorkflow
@{
    ViewData["Title"] = "Workflow Details";
    var remarks = ViewBag.Remarks as List<PrisonEmployeeManagement.Models.FileWorkflowRemark>;
    var currentUserId = ViewBag.CurrentUserId as int? ?? 0;
    var canAct = Model.ToEmployeeId == currentUserId && Model.Status == "Pending";
    var canClose = (Model.Status == "Approved" || Model.Status == "Completed") && Model.Status != "Closed";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h3><i class="fas fa-tasks"></i> Workflow Details: @Model.WorkflowNumber</h3>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <div class="alert alert-@(Model.Priority == "Urgent" ? "danger" : Model.Priority == "High" ? "warning" : "info")">
                    <strong>File:</strong> @Model.File?.FileNumber - @Model.File?.FileTitle<br />
                    <strong>Subject:</strong> @Model.Subject<br />
                    <strong>Priority:</strong> @Model.Priority
                    @if (Model.IsUrgent)
                    {
                        <span class="badge bg-danger ms-2">URGENT</span>
                    }
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">From:</dt>
                            <dd class="col-sm-8">@Model.FromEmployee?.FullName (@Model.FromDepartment)</dd>
                            
                            <dt class="col-sm-4">To:</dt>
                            <dd class="col-sm-8">@Model.ToEmployee?.FullName (@Model.ToDepartment)</dd>
                            
                            <dt class="col-sm-4">Sent Date:</dt>
                            <dd class="col-sm-8">@Model.SentDate.ToString("MM/dd/yyyy HH:mm")</dd>
                            
                            <dt class="col-sm-4">Received Date:</dt>
                            <dd class="col-sm-8">@(Model.ReceivedDate?.ToString("MM/dd/yyyy HH:mm") ?? "Not yet received")</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-@(Model.Status == "Completed" ? "success" : 
                                                      Model.Status == "Pending" ? "warning" : 
                                                      Model.Status == "Rejected" ? "danger" : 
                                                      Model.Status == "Closed" ? "secondary" : "info")">
                                    @Model.Status
                                </span>
                            </dd>
                            
                            <dt class="col-sm-4">Priority:</dt>
                            <dd class="col-sm-8">@Model.Priority</dd>
                            
                            <dt class="col-sm-4">Due Date:</dt>
                            <dd class="col-sm-8">@(Model.DueDate?.ToString("MM/dd/yyyy") ?? "N/A")</dd>
                            
                            <dt class="col-sm-4">Completed Date:</dt>
                            <dd class="col-sm-8">@(Model.CompletedDate?.ToString("MM/dd/yyyy HH:mm") ?? "Not completed")</dd>
                        </dl>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="alert alert-secondary">
                        <strong>Description:</strong><br />
                        @Model.Description
                    </div>
                }

                <h5><i class="fas fa-history"></i> Timeline & Remarks</h5>
                <div class="timeline">
                    @if (remarks != null && remarks.Any())
                    {
                        foreach (var remark in remarks.OrderBy(r => r.CreatedAt))
                        {
                            <div class="timeline-item mb-3">
                                <div class="card border-left-@(remark.ActionType == "Send" ? "primary" : 
                                                              remark.ActionType == "Receive" ? "info" :
                                                              remark.ActionType == "Approve" ? "success" :
                                                              remark.ActionType == "Reject" ? "danger" : 
                                                              remark.ActionType == "Close" ? "secondary" : "secondary")">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <strong><i class="fas fa-user"></i> @remark.Employee?.FullName</strong>
                                                <span class="badge bg-@(remark.ActionType == "Send" ? "primary" : 
                                                                      remark.ActionType == "Receive" ? "info" :
                                                                      remark.ActionType == "Approve" ? "success" :
                                                                      remark.ActionType == "Reject" ? "danger" : 
                                                                      remark.ActionType == "Close" ? "secondary" : "secondary") ms-2">
                                                    @remark.ActionType
                                                </span>
                                            </div>
                                            <small class="text-muted">
                                                <i class="fas fa-clock"></i> @remark.CreatedAt.ToString("MM/dd/yyyy HH:mm")
                                            </small>
                                        </div>
                                        <p class="mt-2 mb-0">@remark.Remark</p>
                                        @if (!string.IsNullOrEmpty(remark.AttachmentPath))
                                        {
                                            <div class="mt-2">
                                                <a href="@remark.AttachmentPath" class="btn btn-sm btn-link" target="_blank">
                                                    <i class="fas fa-paperclip"></i> View Attachment
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info">No remarks added yet.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        @if (canAct)
        {
            @await Html.PartialAsync("_AddRemarkPartial", Model.Id)
        }

        @if (canClose)
        {
            <div class="card mt-3">
                <div class="card-header bg-danger text-white">
                    <h5><i class="fas fa-archive"></i> Close File</h5>
                </div>
                <div class="card-body">
                    <p>Once closed, no further actions can be taken on this file.</p>
                    <a asp-action="CloseWorkflow" asp-route-id="@Model.Id" class="btn btn-danger w-100" 
                       onclick="return confirm('Are you sure you want to close this file? This action cannot be undone.')">
                        <i class="fas fa-archive"></i> Close File
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding: 20px 0;
    }
    
    .timeline-item {
        position: relative;
        margin-bottom: 20px;
    }
    
    .border-left-primary {
        border-left: 4px solid #007bff;
    }
    
    .border-left-info {
        border-left: 4px solid #17a2b8;
    }
    
    .border-left-success {
        border-left: 4px solid #28a745;
    }
    
    .border-left-danger {
        border-left: 4px solid #dc3545;
    }
    
    .border-left-secondary {
        border-left: 4px solid #6c757d;
    }
    
    .card-body {
        position: relative;
    }
    
    .badge {
        font-size: 0.8em;
    }
</style>


