@model PrisonEmployeeManagement.Models.Employee
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-warning">
            <h3>Edit Employee: @Model.FullName</h3>
        </div>
        <div class="card-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }
            
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="CreatedBy" />
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="EmployeeNumber" class="fw-bold"></label>
                            <input asp-for="EmployeeNumber" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="BadgeNumber" class="fw-bold"></label>
                            <input asp-for="BadgeNumber" class="form-control" />
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="FirstName" class="fw-bold"></label>
                            <input asp-for="FirstName" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="LastName" class="fw-bold"></label>
                            <input asp-for="LastName" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="MiddleName" class="fw-bold"></label>
                            <input asp-for="MiddleName" class="form-control" />
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="DateOfBirth" class="fw-bold"></label>
                            <input asp-for="DateOfBirth" class="form-control" type="date" required />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="Gender" class="fw-bold"></label>
                            <select asp-for="Gender" class="form-control" asp-items="ViewBag.Genders" required>
                                <option value="">Select Gender</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="HireDate" class="fw-bold"></label>
                            <input asp-for="HireDate" class="form-control" type="date" required />
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Position" class="fw-bold"></label>
                            <input asp-for="Position" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Department" class="fw-bold"></label>
                            <input asp-for="Department" class="form-control" required />
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Email" class="fw-bold"></label>
                            <input asp-for="Email" class="form-control" type="email" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="PhoneNumber" class="fw-bold"></label>
                            <input asp-for="PhoneNumber" class="form-control" required />
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Address" class="fw-bold"></label>
                            <input asp-for="Address" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="City" class="fw-bold"></label>
                            <input asp-for="City" class="form-control" />
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="State" class="fw-bold"></label>
                            <input asp-for="State" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="ZipCode" class="fw-bold"></label>
                            <input asp-for="ZipCode" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="EmploymentStatus" class="fw-bold"></label>
                            <select asp-for="EmploymentStatus" class="form-control" asp-items="ViewBag.Statuses" required>
                                <option value="">Select Status</option>
                            </select>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="ShiftSchedule" class="fw-bold"></label>
                            <select asp-for="ShiftSchedule" class="form-control" asp-items="ViewBag.Shifts">
                                <option value="">Select Shift</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="SecurityClearanceLevel" class="fw-bold"></label>
                            <select asp-for="SecurityClearanceLevel" class="form-control" asp-items="ViewBag.SecurityLevels">
                                <option value="">Select Clearance</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="Rank" class="fw-bold"></label>
                            <select asp-for="Rank" class="form-control" asp-items="ViewBag.Ranks">
                                <option value="">Select Rank</option>
                            </select>
                        </div>
                    </div>
                </div>
                
                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
}