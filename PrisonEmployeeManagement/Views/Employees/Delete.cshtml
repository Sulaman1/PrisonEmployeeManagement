@model PrisonEmployeeManagement.Models.Employee
@{
    ViewData["Title"] = "Delete Employee";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h3>Delete Employee</h3>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <h4>Are you sure you want to delete this employee?</h4>
                <p>This action cannot be undone.</p>
            </div>
            
            <dl class="row">
                <dt class="col-sm-3">Employee ID</dt>
                <dd class="col-sm-9">@Model.EmployeeNumber</dd>
                
                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">@Model.FullName</dd>
                
                <dt class="col-sm-3">Position</dt>
                <dd class="col-sm-9">@Model.Position</dd>
                
                <dt class="col-sm-3">Department</dt>
                <dd class="col-sm-9">@Model.Department</dd>
                
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>
                
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.EmploymentStatus</dd>
            </dl>
            
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>