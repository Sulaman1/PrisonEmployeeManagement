@model PrisonEmployeeManagement.Models.EmployeeLeave
@{
    ViewData["Title"] = "Delete Leave";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h3>Delete Leave Record</h3>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <h4>Are you sure you want to delete this leave record?</h4>
            <p>This action cannot be undone.</p>
        </div>
        
        <dl class="row">
            <dt class="col-sm-3">Leave Type:</dt>
            <dd class="col-sm-9">@Model.LeaveType</dd>
            
            <dt class="col-sm-3">Start Date:</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("MM/dd/yyyy")</dd>
            
            <dt class="col-sm-3">End Date:</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("MM/dd/yyyy")</dd>
            
            <dt class="col-sm-3">Total Days:</dt>
            <dd class="col-sm-9">@Model.TotalDays</dd>
            
            <dt class="col-sm-3">Status:</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            
            <dt class="col-sm-3">Reason:</dt>
            <dd class="col-sm-9">@Model.Reason</dd>
        </dl>
        
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EmployeeId" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" asp-route-employeeId="@Model.EmployeeId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>