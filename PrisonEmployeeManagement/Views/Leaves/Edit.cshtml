@model PrisonEmployeeManagement.Models.EmployeeLeave
@{
    ViewData["Title"] = "Edit Leave";
}

<div class="card">
    <div class="card-header bg-warning text-white">
        <h3>Edit Leave Record</h3>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EmployeeId" />
            <input type="hidden" asp-for="CreatedAt" />
            
            <div class="form-group mb-3">
                <label asp-for="LeaveType" class="fw-bold"></label>
                <select asp-for="LeaveType" class="form-control" asp-items="ViewBag.LeaveTypes" required></select>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="StartDate" class="fw-bold"></label>
                        <input asp-for="StartDate" class="form-control" type="date" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="EndDate" class="fw-bold"></label>
                        <input asp-for="EndDate" class="form-control" type="date" required />
                    </div>
                </div>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Reason" class="fw-bold"></label>
                <textarea asp-for="Reason" class="form-control" rows="3" required></textarea>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Status" class="fw-bold"></label>
                <select asp-for="Status" class="form-control" asp-items="ViewBag.Statuses"></select>
            </div>
            
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" asp-route-employeeId="@Model.EmployeeId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>