@model IEnumerable<PrisonEmployeeManagement.Models.NotificationViewModel>
@{
    ViewData["Title"] = "Notifications";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h3><i class="fas fa-bell"></i> Notifications</h3>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <button onclick="markAllAsRead()" class="btn btn-info">
                <i class="fas fa-check-double"></i> Mark All as Read
            </button>
        </div>

        <div class="list-group">
            @foreach (var item in Model)
            {
                <div class="list-group-item @(item.IsRead ? "" : "list-group-item-primary")" id="notification-@item.Id">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">
                                @if (!item.IsRead)
                                {
                                    <span class="badge bg-danger me-2">New</span>
                                }
                                <i class="fas fa-@(item.NotificationType == "FileReceived" ? "inbox" :
                                                 item.NotificationType == "FileForwarded" ? "share" :
                                                 item.NotificationType == "RemarkAdded" ? "comment" :
                                                 item.NotificationType == "Approved" ? "check-circle" :
                                                 item.NotificationType == "Rejected" ? "times-circle" :
                                                 item.NotificationType == "Closed" ? "archive" : "bell")"></i>
                                @item.Title
                            </h5>
                            <p class="mb-1">@item.Message</p>
                            <small class="text-muted">
                                <i class="fas fa-clock"></i> @item.CreatedAt.ToString("MM/dd/yyyy HH:mm")
                            </small>
                        </div>
                        <div>
                            @if (!item.IsRead)
                            {
                                <button onclick="markAsRead(@item.Id)" class="btn btn-sm btn-success">
                                    <i class="fas fa-check"></i> Mark Read
                                </button>
                            }
                            @if (item.WorkflowId.HasValue)
                            {
                                <a asp-controller="Workflow" asp-action="Details" asp-route-id="@item.WorkflowId" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> View
                                </a>
                            }
                            <button onclick="deleteNotification(@item.Id)" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">
                <i class="fas fa-bell-slash"></i> No notifications found.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function markAsRead(id) {
            $.post('/Notification/MarkAsRead', { id: id }, function() {
                $('#notification-' + id).removeClass('list-group-item-primary');
                location.reload();
            });
        }

        function markAllAsRead() {
            $.post('/Notification/MarkAllAsRead', function() {
                location.reload();
            });
        }

        function deleteNotification(id) {
            if (confirm('Are you sure you want to delete this notification?')) {
                $.post('/Notification/Delete', { id: id }, function() {
                    $('#notification-' + id).remove();
                });
            }
        }

        // Auto-refresh unread count every 30 seconds
        setInterval(function() {
            $.get('/Notification/UnreadCount', function(data) {
                $('#notificationCount').text(data.count);
                if (data.count > 0) {
                    $('#notificationCount').show();
                } else {
                    $('#notificationCount').hide();
                }
            });
        }, 30000);
    </script>
}