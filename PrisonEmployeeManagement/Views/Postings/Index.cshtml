@model IEnumerable<PrisonEmployeeManagement.Models.EmployeePosting>
@{
    ViewData["Title"] = "Posting History";
    int employeeId = ViewBag.EmployeeId;
    string employeeName = ViewBag.EmployeeName;
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h3>Posting History - @employeeName</h3>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        
        <div class="mb-3">
            <a asp-action="Create" asp-route-employeeId="@employeeId" class="btn btn-success">
                <i class="fas fa-plus"></i> Add Posting
            </a>
            <a asp-controller="Employees" asp-action="Details" asp-route-id="@employeeId" class="btn btn-secondary">
                Back to Employee
            </a>
        </div>
        
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr class="table-dark">
                        <th>Location/Facility</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsCurrent ? "table-success" : "")">
                            <td>@item.Location</td>
                            <td>@item.Department</td>
                            <td>@item.Position</td>
                            <td>@item.StartDate.ToString("MM/dd/yyyy")</td>
                            <td>@(item.EndDate?.ToString("MM/dd/yyyy") ?? "Present")</td>
                            <td>
                                @if (item.IsCurrent)
                                {
                                    <span class="badge bg-success">Current</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Previous</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Any())
        {
            <div class="alert alert-info">No posting records found.</div>
        }
    </div>
</div>