@{
    ViewData["Title"] = "Training & Awards";
    int employeeId = ViewBag.EmployeeId;
    string employeeName = ViewBag.EmployeeName;
    var trainings = ViewBag.Trainings as IEnumerable<PrisonEmployeeManagement.Models.EmployeeTraining>;
    var awards = ViewBag.Awards as IEnumerable<PrisonEmployeeManagement.Models.EmployeeAward>;
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h3>Training & Awards - @employeeName</h3>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        
        <div class="mb-3">
            <a asp-action="CreateTraining" asp-route-employeeId="@employeeId" class="btn btn-success">
                Add Training
            </a>
            <a asp-action="CreateAward" asp-route-employeeId="@employeeId" class="btn btn-info">
                Add Award
            </a>
            <a asp-controller="Employees" asp-action="Details" asp-route-id="@employeeId" class="btn btn-secondary">
                Back to Employee
            </a>
        </div>
        
        <!-- Training Section -->
        <h4>Training Records</h4>
        <div class="table-responsive mb-4">
            <table class="table table-bordered">
                <thead>
                    <tr class="table-dark">
                        <th>Training Name</th>
                        <th>Provider</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Certificate</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (trainings != null && trainings.Any())
                    {
                        @foreach (var item in trainings)
                        {
                            <tr>
                                <td>@item.TrainingName</td>
                                <td>@item.Provider</td>
                                <td>@item.StartDate.ToString("MM/dd/yyyy")</td>
                                <td>@(item.EndDate?.ToString("MM/dd/yyyy") ?? "In Progress")</td>
                                <td>
                                    <span class="badge bg-@(item.Status == "Completed" ? "success" : "warning")">
                                        @item.Status
                                    </span>
                                </td>
                                <td>@item.CertificateNumber</td>
                                <td>
                                    <a asp-action="EditTraining" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                    <button onclick="deleteTraining(@item.Id)" class="btn btn-sm btn-danger">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">No training records found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Awards Section -->
        <h4>Awards & Recognitions</h4>
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr class="table-dark">
                        <th>Award Name</th>
                        <th>Category</th>
                        <th>Award Date</th>
                        <th>Presented By</th>
                        <th>Certificate</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (awards != null && awards.Any())
                    {
                        @foreach (var item in awards)
                        {
                            <tr>
                                <td>@item.AwardName</td>
                                <td>@item.Category</td>
                                <td>@item.AwardDate.ToString("MM/dd/yyyy")</td>
                                <td>@item.PresentedBy</td>
                                <td>@item.CertificateNumber</td>
                                <td>
                                    <a asp-action="EditAward" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                    <button onclick="deleteAward(@item.Id)" class="btn btn-sm btn-danger">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">No award records found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteTraining(id) {
            if (confirm('Are you sure you want to delete this training record?')) {
                $.post('/Training/DeleteTraining', { id: id }, function() {
                    location.reload();
                });
            }
        }
        
        function deleteAward(id) {
            if (confirm('Are you sure you want to delete this award record?')) {
                $.post('/Training/DeleteAward', { id: id }, function() {
                    location.reload();
                });
            }
        }
    </script>
}