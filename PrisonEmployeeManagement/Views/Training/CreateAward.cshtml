@model PrisonEmployeeManagement.Models.EmployeeAward
@{
    ViewData["Title"] = "Add Award";
}

<div class="card">
    <div class="card-header bg-success text-white">
        <h3>Add Award for @ViewBag.EmployeeName</h3>
    </div>
    <div class="card-body">
        <form asp-action="CreateAward" method="post">
            <input type="hidden" asp-for="EmployeeId" />
            
            <div class="form-group mb-3">
                <label asp-for="AwardName" class="fw-bold"></label>
                <input asp-for="AwardName" class="form-control" required />
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Category" class="fw-bold"></label>
                <select asp-for="Category" class="form-control" asp-items="ViewBag.AwardCategories"></select>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="AwardDate" class="fw-bold"></label>
                <input asp-for="AwardDate" class="form-control" type="date" required />
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="PresentedBy" class="fw-bold"></label>
                <input asp-for="PresentedBy" class="form-control" />
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Reason" class="fw-bold"></label>
                <textarea asp-for="Reason" class="form-control" rows="3"></textarea>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="CertificateNumber" class="fw-bold"></label>
                        <input asp-for="CertificateNumber" class="form-control" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MonetaryValue" class="fw-bold"></label>
                        <input asp-for="MonetaryValue" class="form-control" type="number" step="0.01" />
                    </div>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" asp-route-employeeId="@Model.EmployeeId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>