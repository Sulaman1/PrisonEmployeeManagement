@model IEnumerable<PrisonEmployeeManagement.Models.Employee>
@{
    ViewData["Title"] = "Manage Employees";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h3><i class="fas fa-users"></i> Manage Employees</h3>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <div class="mb-3">
            <a asp-action="CreateEmployee" class="btn btn-success">
                <i class="fas fa-plus"></i> Add New Employee
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Employee #</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.EmployeeNumber</td
                            <td>@item.FullName</td
                            <td>@item.Email</td
                            <td>@item.Department</td
                            <td>@item.Position</td
                            <td>
                                <span class="badge bg-@(item.EmploymentStatus == "Active" ? "success" : "secondary")">
                                    @item.EmploymentStatus
                                </span>
                             </td
                            <td>
                                <a asp-action="EditEmployee" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <button onclick="deleteEmployee(@item.Id)" class="btn btn-sm btn-danger">Delete</button>
                             </td
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteEmployee(id) {
            if (confirm('Are you sure you want to delete this employee?')) {
                $.post('/Admin/DeleteEmployee', { id: id }, function() {
                    location.reload();
                });
            }
        }
    </script>
}