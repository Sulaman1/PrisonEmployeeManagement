@model PrisonEmployeeManagement.Models.Employee
@{
    ViewData["Title"] = "Create Employee";
}

<div class="card">
    <div class="card-header bg-success text-white">
        <h3><i class="fas fa-user-plus"></i> Create New Employee</h3>
    </div>
    <div class="card-body">
        <form asp-action="CreateEmployee" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="EmployeeNumber" class="fw-bold"></label>
                        <input asp-for="EmployeeNumber" class="form-control" placeholder="Auto-generated if left empty" />
                        <span asp-validation-for="EmployeeNumber" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Email" class="fw-bold"></label>
                        <input asp-for="Email" class="form-control" type="email" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FirstName" class="fw-bold"></label>
                        <input asp-for="FirstName" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="LastName" class="fw-bold"></label>
                        <input asp-for="LastName" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="MiddleName" class="fw-bold"></label>
                        <input asp-for="MiddleName" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="DateOfBirth" class="fw-bold"></label>
                        <input asp-for="DateOfBirth" class="form-control" type="date" required />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Gender" class="fw-bold"></label>
                        <select asp-for="Gender" class="form-control" asp-items="ViewBag.Genders" required></select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="HireDate" class="fw-bold"></label>
                        <input asp-for="HireDate" class="form-control" type="date" required />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Position" class="fw-bold"></label>
                        <input asp-for="Position" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Department" class="fw-bold"></label>
                        <select asp-for="Department" class="form-control" asp-items="ViewBag.Departments" required></select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="PhoneNumber" class="fw-bold"></label>
                        <input asp-for="PhoneNumber" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="BadgeNumber" class="fw-bold"></label>
                        <input asp-for="BadgeNumber" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="EmploymentStatus" class="fw-bold"></label>
                        <select asp-for="EmploymentStatus" class="form-control" asp-items="ViewBag.Statuses"></select>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Address" class="fw-bold"></label>
                <input asp-for="Address" class="form-control" />
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="form-group mb-3">
                        <label asp-for="City" class="fw-bold"></label>
                        <input asp-for="City" class="form-control" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group mb-3">
                        <label asp-for="State" class="fw-bold"></label>
                        <input asp-for="State" class="form-control" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group mb-3">
                        <label asp-for="ZipCode" class="fw-bold"></label>
                        <input asp-for="ZipCode" class="form-control" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group mb-3">
                        <label asp-for="Country" class="fw-bold"></label>
                        <input asp-for="Country" class="form-control" value="USA" />
                    </div>
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create Employee</button>
                <a asp-action="Employees" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}