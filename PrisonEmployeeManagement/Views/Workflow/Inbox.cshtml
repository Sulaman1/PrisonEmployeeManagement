@model IEnumerable<PrisonEmployeeManagement.Models.FileWorkflow>
@{
    ViewData["Title"] = "Inbox";
    int employeeId = ViewBag.EmployeeId ?? 0;
    string currentStatus = ViewBag.CurrentStatus ?? "Pending";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h3><i class="fas fa-inbox"></i> Inbox</h3>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <div class="row mb-3">
            <div class="col-md-3">
                <form method="get" asp-action="Inbox">
                    <input type="hidden" name="employeeId" value="@employeeId" />
                    <select name="status" class="form-control" asp-items="ViewBag.Statuses" onchange="this.form.submit()">
                        <option value="">Filter by Status</option>
                    </select>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Workflow #</th>
                        <th>File</th>
                        <th>From</th>
                        <th>Subject</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Sent Date</th>
                        <th>Due Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsUrgent ? "table-danger" : item.DueDate < DateTime.Today ? "table-warning" : "")">
                            <td>@item.WorkflowNumber</td
                            <td>@item.File?.FileNumber</td
                            <td>@item.FromEmployee?.FullName</td
                            <td>@item.Subject</td
                            <td>
                                @if (item.Priority == "Urgent")
                                {
                                    <span class="badge bg-danger">Urgent</span>
                                }
                                else if (item.Priority == "High")
                                {
                                    <span class="badge bg-warning">High</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">@item.Priority</span>
                                }
                             </td
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                                else if (item.Status == "In Progress")
                                {
                                    <span class="badge bg-info">In Progress</span>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else if (item.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                             </td
                            <td>@item.SentDate.ToString("MM/dd/yyyy")</td
                            <td>
                                @if (item.DueDate.HasValue)
                                {
                                    <span class="@(item.DueDate < DateTime.Today ? "text-danger" : "")">
                                        @item.DueDate.Value.ToString("MM/dd/yyyy")
                                    </span>
                                }
                             </td
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info" title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Track" asp-route-id="@item.Id" class="btn btn-secondary" title="Track">
                                        <i class="fas fa-chart-line"></i>
                                    </a>
                                </div>
                             </td
                         </tr>
                    }
                </tbody>
             </table>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">No files in your inbox.</div>
        }
    </div>
</div>