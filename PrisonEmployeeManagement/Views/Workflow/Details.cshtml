@model PrisonEmployeeManagement.Models.FileWorkflowViewModel
@{
    ViewData["Title"] = "Workflow Details";
    var canAct = ViewBag.CanAct as bool? ?? false;
    var canClose = ViewBag.CanClose as bool? ?? false;
    var currentEmployeeId = ViewBag.CurrentEmployeeId as int? ?? 0;
}
@await Html.PartialAsync("_FileViewModal")


<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h3><i class="fas fa-tasks"></i> Workflow Details</h3>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <div class="alert alert-@(Model.Priority == "Urgent" ? "danger" : Model.Priority == "High" ? "warning" : "info")">
                    <strong>Workflow #:</strong> @Model.WorkflowNumber<br />
                    <strong>File:</strong> @Model.FileNumber - @Model.FileTitle<br />
                    <strong>Subject:</strong> @Model.Subject
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">From:</dt>
                            <dd class="col-sm-8">@Model.FromEmployee (@Model.FromDepartment)</dd>
                            
                            <dt class="col-sm-4">To:</dt>
                            <dd class="col-sm-8">@Model.ToEmployee (@Model.ToDepartment)</dd>
                            
                            <dt class="col-sm-4">Sent Date:</dt>
                            <dd class="col-sm-8">@Model.SentDate.ToString("MM/dd/yyyy HH:mm")</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-@(Model.Status == "Completed" ? "success" : 
                                                      Model.Status == "Pending" ? "warning" : 
                                                      Model.Status == "Rejected" ? "danger" : 
                                                      Model.Status == "Closed" ? "secondary" : "info")">
                                    @Model.Status
                                </span>
                            </dd>
                            
                            <dt class="col-sm-4">Priority:</dt>
                            <dd class="col-sm-8">@Model.Priority</dd>
                            
                            <dt class="col-sm-4">Due Date:</dt>
                            <dd class="col-sm-8">@(Model.DueDate?.ToString("MM/dd/yyyy") ?? "N/A")</dd>
                        </dl>
                    </div>
                </div>

<a href="#" onclick="viewFileDetails(@Model.Id)" class="btn btn-info">
    <i class="fas fa-eye"></i> View File
</a>

                <h5>Remarks & Timeline</h5>
                <div class="timeline">
                    @foreach (var remark in Model.Remarks.OrderBy(r => r.CreatedAt))
                    {
                        <div class="timeline-item mb-3">
                            <div class="card border-left-@(remark.ActionType == "Send" ? "primary" : 
                                                          remark.ActionType == "Receive" ? "info" :
                                                          remark.ActionType == "Approve" ? "success" :
                                                          remark.ActionType == "Reject" ? "danger" : 
                                                          remark.ActionType == "Close" ? "secondary" : "secondary")">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <strong>@remark.EmployeeName</strong>
                                        <small class="text-muted">@remark.CreatedAt.ToString("MM/dd/yyyy HH:mm")</small>
                                    </div>
                                    <span class="badge bg-@(remark.ActionType == "Send" ? "primary" : 
                                                          remark.ActionType == "Receive" ? "info" :
                                                          remark.ActionType == "Approve" ? "success" :
                                                          remark.ActionType == "Reject" ? "danger" : 
                                                          remark.ActionType == "Close" ? "secondary" : "secondary") mb-2">
                                        @remark.ActionType
                                    </span>
                                    <p class="mt-2 mb-0">@remark.Remark</p>
                                    @if (!string.IsNullOrEmpty(remark.AttachmentPath))
                                    {
                                        <a href="@remark.AttachmentPath" class="btn btn-sm btn-link" target="_blank">
                                            <i class="fas fa-paperclip"></i> Attachment
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        @if (canAct)
        {
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5><i class="fas fa-comment"></i> Take Action</h5>
                </div>
                <div class="card-body">
                    <form id="remarkForm" asp-action="AddRemark" asp-controller="Workflow" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="workflowId" value="@Model.Id" />
                        
                        <div class="form-group mb-3">
                            <label>Action Type</label>
                            <select name="actionType" id="actionType" class="form-control" required>
                                <option value="">Select Action</option>
                                <option value="Receive">Receive File</option>
                                <option value="Approve">Approve</option>
                                <option value="Reject">Reject</option>
                                <option value="Complete">Complete</option>
                                <option value="Remark">Add Remark Only</option>
                            </select>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label>Remarks</label>
                            <textarea name="ontrol" rows="4" required></textarea>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label>Attachment (Optional)</label>
                            <input type="file" name="attachment" id="attachment" class="form-control" />
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-paper-plane"></i> Submit
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (ViewBag.Employees != null)
        {
            <div class="card mt-3">
                <div class="card-header bg-warning">
                    <h5><i class="fas fa-share"></i> Forward to Another Department</h5>
                </div>
                <div class="card-body">
                    <form id="forwardForm" asp-action="Forward" asp-controller="Workflow" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="workflowId" value="@Model.Id" />
                        
                        <div class="form-group mb-3">
                            <label>To Employee</label>
                            <select name="toEmployeeId" id="toEmployeeId" class="form-control" required>
                                <option value="">Select Employee</option>
                                @foreach (var emp in ViewBag.Employees as SelectList)
                                {
                                    <option value="@emp.Value">@emp.Text</option>
                                }
                            </select>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label>Remark</label>
                            <textarea name="remark" id="forwardRemark" class="form-control" rows="2" required></textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-warning w-100">
                            <i class="fas fa-share"></i> Forward File
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (canClose)
        {
            <div class="card mt-3">
                <div class="card-header bg-danger text-white">
                    <h5><i class="fas fa-archive"></i> Close File</h5>
                </div>
                <div class="card-body">
                    <p>Once closed, no further actions can be taken on this file.</p>
                    <a asp-action="Close" asp-route-id="@Model.Id" class="btn btn-danger w-100" 
                       onclick="return confirm('Are you sure you want to close this file? This action cannot be undone.')">
                        <i class="fas fa-archive"></i> Close File
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#remarkForm').on('submit', function(e) {
                e.preventDefault();
                
                var formData = new FormData(this);
                
                $.ajax({
                    url: '@Url.Action("AddRemark", "Workflow")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('Error: ' + error + '\nStatus: ' + xhr.status);
                    }
                });
            });
            
            $('#forwardForm').on('submit', function(e) {
                e.preventDefault();
                
                var formData = $(this).serialize();
                
                $.ajax({
                    url: '@Url.Action("Forward", "Workflow")',
                    type: 'POST',
                    data: formData,
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('Error: ' + error);
                    }
                });
            });
        });
    </script>
}

<style>
    .timeline {
        position: relative;
        padding: 20px 0;
    }
    
    .timeline-item {
        position: relative;
        margin-bottom: 20px;
    }
    
    .border-left-primary {
        border-left: 4px solid #007bff;
    }
    
    .border-left-info {
        border-left: 4px solid #17a2b8;
    }
    
    .border-left-success {
        border-left: 4px solid #28a745;
    }
    
    .border-left-danger {
        border-left: 4px solid #dc3545;
    }
    
    .border-left-secondary {
        border-left: 4px solid #6c757d;
    }
</style>


