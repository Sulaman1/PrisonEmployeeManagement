@model PrisonEmployeeManagement.Models.FileWorkflow
@{
    ViewData["Title"] = "Send File";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h3><i class="fas fa-paper-plane"></i> Send File</h3>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            <strong>File:</strong> @ViewBag.FileNumber - @ViewBag.FileTitle
        </div>

        <form asp-action="Send" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="FileId" />
            <input type="hidden" asp-for="WorkflowNumber" value="@ViewBag.WorkflowNumber" />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="FromDepartment" class="fw-bold"></label>
                        <select asp-for="FromDepartment" class="form-control" asp-items="ViewBag.Departments" required>
                            <option value="">Select Department</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ToDepartment" class="fw-bold"></label>
                        <select asp-for="ToDepartment" class="form-control" asp-items="ViewBag.Departments" required>
                            <option value="">Select Department</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="FromEmployeeId" class="fw-bold">From Employee</label>
                        <select asp-for="FromEmployeeId" class="form-control" asp-items="ViewBag.Employees" required>
                            <option value="">Select Employee</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ToEmployeeId" class="fw-bold">To Employee</label>
                        <select asp-for="ToEmployeeId" class="form-control" asp-items="ViewBag.Employees" required>
                            <option value="">Select Employee</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Subject" class="fw-bold"></label>
                <input asp-for="Subject" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="fw-bold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Priority" class="fw-bold"></label>
                        <select asp-for="Priority" class="form-control" asp-items="ViewBag.Priorities"></select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="DueDate" class="fw-bold"></label>
                        <input asp-for="DueDate" class="form-control" type="date" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="IsUrgent" class="fw-bold"></label>
                        <input asp-for="IsUrgent" type="checkbox" /> Mark as Urgent
                    </div>
                </div>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-paper-plane"></i> Send File
                </button>
                <a asp-controller="EFiles" asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}