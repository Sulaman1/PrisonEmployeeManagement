@model PrisonEmployeeManagement.Models.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h3><i class="fas fa-user-circle"></i> My Profile</h3>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }
                
                <dl class="row">
                    <dt class="col-sm-3">Full Name:</dt>
                    <dd class="col-sm-9">@Model.FirstName @Model.LastName</dd>
                    
                    <dt class="col-sm-3">Email:</dt>
                    <dd class="col-sm-9">@Model.Email</dd>
                    
                    <dt class="col-sm-3">Employee Number:</dt>
                    <dd class="col-sm-9">@Model.EmployeeNumber</dd>
                    
                    <dt class="col-sm-3">Department:</dt>
                    <dd class="col-sm-9">@Model.Department</dd>
                    
                    <dt class="col-sm-3">Position:</dt>
                    <dd class="col-sm-9">@Model.Position</dd>
                    
                    <dt class="col-sm-3">Roles:</dt>
                    <dd class="col-sm-9">
                        @foreach (var role in Model.Roles)
                        {
                            <span class="badge bg-info">@role</span>
                        }
                    </dd>
                    
                    <dt class="col-sm-3">Account Status:</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </dd>
                    
                    <dt class="col-sm-3">Account Created:</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("MM/dd/yyyy HH:mm")</dd>
                    
                    <dt class="col-sm-3">Last Login:</dt>
                    <dd class="col-sm-9">@Model.LastLoginAt.ToString("MM/dd/yyyy HH:mm")</dd>
                </dl>
                
                <div class="mt-3">
                    <a asp-action="ChangePassword" class="btn btn-warning">
                        <i class="fas fa-key"></i> Change Password
                    </a>
                    <a asp-controller="UserDashboard" asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-dashboard"></i> Go to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5>Quick Actions</h5>
            </div>
            <div class="card-body">
                <a asp-controller="UserDashboard" asp-action="Index" class="btn btn-primary w-100 mb-2">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a asp-controller="UserDashboard" asp-action="MyFiles" asp-route-userId="@ViewBag.UserId" class="btn btn-success w-100 mb-2">
                    <i class="fas fa-folder-open"></i> My Files
                </a>
                <a asp-controller="UserDashboard" asp-action="MyWorkflows" asp-route-userId="@ViewBag.UserId" class="btn btn-info w-100">
                    <i class="fas fa-tasks"></i> My Workflows
                </a>
            </div>
        </div>
    </div>
</div>