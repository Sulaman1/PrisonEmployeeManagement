@model PrisonEmployeeManagement.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h3><i class="fas fa-user-plus"></i> Register New Account</h3>
            </div>
            <div class="card-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }
                
                <div class="alert alert-info">
                    <strong>Note:</strong> Your employee number must be provided by HR. 
                    If you don't have one, please contact your HR department.
                    <hr />
                    <strong>Demo Employee Numbers:</strong> EMP001, EMP002, EMP003, EMP004, EMP005
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="EmployeeNumber" class="fw-bold"></label>
                        <input asp-for="EmployeeNumber" class="form-control" placeholder="Enter your Employee Number" />
                        <span asp-validation-for="EmployeeNumber" class="text-danger"></span>
                        <small class="text-muted">Example: EMP001, EMP002, etc.</small>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="Email" class="fw-bold"></label>
                        <input asp-for="Email" class="form-control" placeholder="Enter your email address" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="Password" class="fw-bold"></label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="Create a password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        <small class="text-muted">Password must be at least 6 characters</small>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="ConfirmPassword" class="fw-bold"></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm your password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group">
                        <button type="submit" class="btn btn-success w-100">
                            <i class="fas fa-user-plus"></i> Register
                        </button>
                    </div>
                    
                    <div class="text-center mt-3">
                        <a asp-action="Login">Already have an account? Login here</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}