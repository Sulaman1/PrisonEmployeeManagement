@model IEnumerable<PrisonEmployeeManagement.Models.PersonalFile>
@{
    ViewData["Title"] = "Personal Files";
}
@await Html.PartialAsync("_FileViewModal")

<div class="card">
    <div class="card-header bg-primary text-white">
        <h3><i class="fas fa-folder-open"></i> Personal Files</h3>
        <p class="mb-0">Viewing files for: @ViewBag.CurrentEmployeeName</p>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="mb-3">
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Add New Personal File
            </a>
        </div>

        <!-- Search and Filter -->
        <form asp-action="Index" method="get" class="mb-4">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="searchTerm" class="form-control" 
                           placeholder="Search by file number, name, sent by..." 
                           value="@ViewBag.SearchTerm" />
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-control" asp-items="ViewBag.Statuses"></select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Filter
                    </button>
                </div>
                <div class="col-md-3">
                    <a asp-action="Index" class="btn btn-secondary w-100">
                        <i class="fas fa-sync-alt"></i> Reset
                    </a>
                </div>
            </div>
        </form>

        <!-- Files Table - Fixed Structure -->
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover" id="personalFilesTable" style="width: 100%;">
                <thead>
                    <tr class="table-dark">
                        <th style="width: 8%">File #</th>
                        <th style="width: 15%">File Name</th>
                        <th style="width: 10%">Sent By</th>
                        <th style="width: 10%">Received Date</th>
                        <th style="width: 10%">Sending Date</th>
                        <th style="width: 8%">Status</th>
                        <th style="width: 7%">Priority</th>
                        <th style="width: 22%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FileNumber</td>
                                <td>@item.FileName</td>
                                <td>@item.SentBy</td>
                                <td>@item.ReceivedDate.ToString("MM/dd/yyyy")</td>
                                <td>@item.DateOfSending.ToString("MM/dd/yyyy")</td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                    else if (item.Status == "In Progress")
                                    {
                                        <span class="badge bg-info">In Progress</span>
                                    }
                                    else if (item.Status == "Approved")
                                    {
                                        <span class="badge bg-success">Approved</span>
                                    }
                                    else if (item.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Priority == "Urgent")
                                    {
                                        <span class="badge bg-danger">Urgent</span>
                                    }
                                    else if (item.Priority == "High")
                                    {
                                        <span class="badge bg-warning">High</span>
                                    }
                                    else if (item.Priority == "Low")
                                    {
                                        <span class="badge bg-secondary">Low</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@item.Priority</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <div class="btn-group btn-group-sm">
                                        <button type="button" class="btn btn-info" onclick="viewFileDetails(@item.Id)" title="Quick View">
                                            <i class="fas fa-eye"></i> PreView
                                        </button>
                                        
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info" title="View Details">
                                            <i class="fas fa-eye"></i> Details
                                        </a>
                                        <a asp-action="AddAction" asp-route-id="@item.Id" class="btn btn-primary" title="Add Action">
                                            <i class="fas fa-plus"></i> Add Action
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning" title="Edit">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger" title="Delete">
                                            <i class="fas fa-trash"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="alert alert-info mb-0">
                                    <i class="fas fa-info-circle"></i> No personal files found. Click "Add New Personal File" to create one.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    
    <script>
        $(document).ready(function() {
            // Initialize DataTable only if there are rows
            if ($('#personalFilesTable tbody tr').length > 0 && $('#personalFilesTable tbody tr td').length > 1) {
                $('#personalFilesTable').DataTable({
                    "pageLength": 10,
                    "order": [[3, "desc"]], // Sort by received date descending
                    "language": {
                        "search": "Search:",
                        "lengthMenu": "Show _MENU_ entries",
                        "info": "Showing _START_ to _END_ of _TOTAL_ entries",
                        "infoEmpty": "Showing 0 to 0 of 0 entries",
                        "zeroRecords": "No matching records found"
                    },
                    "columnDefs": [
                        { "orderable": false, "targets": [7] } // Disable sorting on actions column
                    ]
                });
            }
        });
    </script>
}

<style>
    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
    
    .table {
        margin-bottom: 0;
        min-width: 800px;
    }
    
    .table th, 
    .table td {
        vertical-align: middle;
        white-space: normal;
        word-wrap: break-word;
    }
    
    .btn-group-sm .btn {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
        margin: 0 2px;
    }
    
    .badge {
        font-size: 0.75em;
        padding: 0.35em 0.65em;
    }
    
    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .table th,
        .table td {
            font-size: 0.85rem;
            padding: 0.5rem;
        }
        
        .btn-group-sm .btn {
            padding: 0.2rem 0.4rem;
            font-size: 0.7rem;
        }
    }
</style>

