@model PrisonEmployeeManagement.Models.PersonalFile
@{
    ViewData["Title"] = "File Details";
}

<div class="row">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h3><i class="fas fa-file-alt"></i> File Details: @Model.FileNumber</h3>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }

                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-5">File Name:</dt>
                            <dd class="col-sm-7">@Model.FileName</dd>

                            <dt class="col-sm-5">Received Date:</dt>
                            <dd class="col-sm-7">@Model.ReceivedDate.ToString("MM/dd/yyyy")</dd>

                            <dt class="col-sm-5">Sent By:</dt>
                            <dd class="col-sm-7">@Model.SentBy</dd>

                            <dt class="col-sm-5">Sent By Department:</dt>
                            <dd class="col-sm-7">@Model.SentByDepartment</dd>

                            <dt class="col-sm-5">Date of Sending:</dt>
                            <dd class="col-sm-7">@Model.DateOfSending.ToString("MM/dd/yyyy")</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-5">Status:</dt>
                            <dd class="col-sm-7">
                                <span class="badge bg-@(Model.Status == "Completed" ? "success" : 
                                                      Model.Status == "Pending" ? "warning" : 
                                                      Model.Status == "Rejected" ? "danger" : "info")">
                                    @Model.Status
                                </span>
                            </dd>

                            <dt class="col-sm-5">Priority:</dt>
                            <dd class="col-sm-7">@Model.Priority</dd>

                            <dt class="col-sm-5">Current Location:</dt>
                            <dd class="col-sm-7">@Model.CurrentLocation</dd>

                            <dt class="col-sm-5">Final Decision By:</dt>
                            <dd class="col-sm-7">@Model.FinalDecisionBy</dd>

                            <dt class="col-sm-5">Final Decision Date:</dt>
                            <dd class="col-sm-7">@(Model.FinalDecisionDate?.ToString("MM/dd/yyyy") ?? "N/A")</dd>
                        </dl>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="alert alert-secondary">
                        <strong>Description:</strong><br />@Model.Description
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.ActionTaken))
                {
                    <div class="alert alert-info">
                        <strong>Initial Action Taken:</strong><br />@Model.ActionTaken
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.FinalDecision))
                {
                    <div class="alert alert-success">
                        <strong>Final Decision:</strong><br />@Model.FinalDecision
                    </div>
                }

                <div class="mt-3">
                    <!-- Fix: Use the correct URL format -->
                    <a href="@Url.Action("AddAction", "PersonalFiles", new { id = Model.Id })" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Add New Action
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="fas fa-edit"></i> Edit File
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5><i class="fas fa-history"></i> Action History</h5>
            </div>
            <div class="card-body" style="max-height: 500px; overflow-y: auto;">
                @if (Model.Actions != null && Model.Actions.Any())
                {
                    @foreach (var action in Model.Actions.OrderByDescending(a => a.ActionDate))
                    {
                        <div class="card mb-2">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong class="text-primary">@action.ActionDate.ToString("MM/dd/yyyy")</strong>
                                        <br />
                                        <small class="text-muted">By: @action.ActionBy</small>
                                    </div>
                                    <div>
                                        <a asp-action="EditAction" asp-route-id="@action.Id" class="btn btn-sm btn-warning" title="Edit Action">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button onclick="deleteAction(@action.Id)" class="btn btn-sm btn-danger" title="Delete Action">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                                <hr class="my-2" />
                                <p class="mb-1"><strong>Action:</strong> @action.ActionTaken</p>
                                @if (!string.IsNullOrEmpty(action.Remarks))
                                {
                                    <p class="mb-1"><strong>Remarks:</strong> @action.Remarks</p>
                                }
                                @if (action.NextActionDate.HasValue)
                                {
                                    <p class="mb-0"><strong>Next Action:</strong> @action.NextActionDate.Value.ToString("MM/dd/yyyy")</p>
                                }
                                @if (!string.IsNullOrEmpty(action.StatusAfterAction))
                                {
                                    <p class="mb-0"><strong>Status Updated To:</strong> 
                                        <span class="badge bg-info">@action.StatusAfterAction</span>
                                    </p>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle"></i> No actions recorded yet.
                        <br />
                        <a href="@Url.Action("AddAction", "PersonalFiles", new { id = Model.Id })" class="btn btn-primary btn-sm mt-2">
                            Add First Action
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteAction(id) {
            if (confirm('Are you sure you want to delete this action?')) {
                $.ajax({
                    url: '@Url.Action("DeleteAction", "PersonalFiles")',
                    type: 'POST',
                    data: { id: id },
                    success: function(response) {
                        location.reload();
                    },
                    error: function(xhr, status, error) {
                        alert('Error deleting action: ' + error);
                    }
                });
            }
        }
    </script>
}

