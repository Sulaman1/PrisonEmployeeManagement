@model PrisonEmployeeManagement.Models.PersonalFile
@{
    ViewData["Title"] = "Delete Personal File";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h3><i class="fas fa-trash"></i> Delete Personal File</h3>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <h4>Are you sure you want to delete this file?</h4>
            <p>This action cannot be undone. All associated actions will also be deleted.</p>
        </div>

        <dl class="row">
            <dt class="col-sm-3">File Number:</dt>
            <dd class="col-sm-9">@Model.FileNumber</dd>

            <dt class="col-sm-3">File Name:</dt>
            <dd class="col-sm-9">@Model.FileName</dd>

            <dt class="col-sm-3">Sent By:</dt>
            <dd class="col-sm-9">@Model.SentBy</dd>

            <dt class="col-sm-3">Received Date:</dt>
            <dd class="col-sm-9">@Model.ReceivedDate.ToString("MM/dd/yyyy")</dd>

            <dt class="col-sm-3">Status:</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

