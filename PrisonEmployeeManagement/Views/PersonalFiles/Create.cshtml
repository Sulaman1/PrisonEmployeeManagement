@model PrisonEmployeeManagement.Models.PersonalFile
@{
    ViewData["Title"] = "Create Personal File";
}

<div class="card">
    <div class="card-header bg-success text-white">
        <h3><i class="fas fa-plus"></i> Create Personal File</h3>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="FileNumber" class="fw-bold"></label>
                        <input asp-for="FileNumber" class="form-control" readonly value="@ViewBag.FileNumber" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="FileName" class="fw-bold"></label>
                        <input asp-for="FileName" class="form-control" required />
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="fw-bold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ReceivedDate" class="fw-bold"></label>
                        <input asp-for="ReceivedDate" class="form-control" type="date" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="DateOfSending" class="fw-bold"></label>
                        <input asp-for="DateOfSending" class="form-control" type="date" required />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="SentBy" class="fw-bold"></label>
                        <input asp-for="SentBy" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="SentByDepartment" class="fw-bold"></label>
                        <input asp-for="SentByDepartment" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ActionTaken" class="fw-bold"></label>
                <textarea asp-for="ActionTaken" class="form-control" rows="2"></textarea>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Status" class="fw-bold"></label>
                        <select asp-for="Status" class="form-control" asp-items="ViewBag.Statuses"></select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Priority" class="fw-bold"></label>
                        <select asp-for="Priority" class="form-control" asp-items="ViewBag.Priorities"></select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="CurrentLocation" class="fw-bold"></label>
                        <input asp-for="CurrentLocation" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="FinalDecisionBy" class="fw-bold"></label>
                        <input asp-for="FinalDecisionBy" class="form-control" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="FinalDecisionDate" class="fw-bold"></label>
                        <input asp-for="FinalDecisionDate" class="form-control" type="date" />
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FinalDecision" class="fw-bold"></label>
                <textarea asp-for="FinalDecision" class="form-control" rows="2"></textarea>
            </div>

            <input type="hidden" asp-for="EmployeeId" />

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


