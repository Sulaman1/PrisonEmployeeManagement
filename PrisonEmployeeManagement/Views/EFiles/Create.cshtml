@model PrisonEmployeeManagement.Models.EFile
@{
    ViewData["Title"] = "Upload File";
}

<div class="card">
    <div class="card-header bg-success text-white">
        <h3><i class="fas fa-upload"></i> Upload New File</h3>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="FileNumber" class="fw-bold"></label>
                        <input asp-for="FileNumber" class="form-control" readonly value="@ViewBag.FileNumber" />
                        <span asp-validation-for="FileNumber" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="FileTitle" class="fw-bold"></label>
                        <input asp-for="FileTitle" class="form-control" required />
                        <span asp-validation-for="FileTitle" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Category" class="fw-bold"></label>
                        <select asp-for="Category" class="form-control" asp-items="ViewBag.Categories" required>
                            <option value="">Select Category</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="EmployeeId" class="fw-bold">Related Employee</label>
                        <select asp-for="EmployeeId" class="form-control" asp-items="ViewBag.Employees">
                            <option value="">Select Employee (Optional)</option>
                        </select>
                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ConfidentialLevel" class="fw-bold"></label>
                        <select asp-for="ConfidentialLevel" class="form-control" asp-items="ViewBag.ConfidentialLevels" required>
                            <option value="">Select Level</option>
                        </select>
                        <span asp-validation-for="ConfidentialLevel" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Status" class="fw-bold"></label>
                        <select asp-for="Status" class="form-control" asp-items="ViewBag.Statuses"></select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="fw-bold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ExpiryDate" class="fw-bold"></label>
                        <input asp-for="ExpiryDate" class="form-control" type="date" />
                        <span asp-validation-for="ExpiryDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Tags" class="fw-bold"></label>
                        <input asp-for="Tags" class="form-control" placeholder="Comma-separated tags" />
                        <span asp-validation-for="Tags" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label class="fw-bold">Select File</label>
                <input type="file" name="uploadedFile" class="form-control" required />
                <small class="text-muted">Supported formats: PDF, DOC, DOCX, XLS, XLSX, JPG, PNG (Max 10MB)</small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Notes" class="fw-bold"></label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Upload File
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}