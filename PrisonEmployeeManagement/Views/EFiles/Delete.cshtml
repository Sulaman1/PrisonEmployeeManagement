@model PrisonEmployeeManagement.Models.EFile
@{
    ViewData["Title"] = "Delete File";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h3><i class="fas fa-trash"></i> Delete File</h3>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <h4>Are you sure you want to delete this file?</h4>
            <p>This action cannot be undone. The physical file will also be deleted from the server.</p>
        </div>

        <dl class="row">
            <dt class="col-sm-3">File Number:</dt>
            <dd class="col-sm-9">@Model.FileNumber</dd>

            <dt class="col-sm-3">File Title:</dt>
            <dd class="col-sm-9">@Model.FileTitle</dd>

            <dt class="col-sm-3">Category:</dt>
            <dd class="col-sm-9">@Model.Category</dd>

            <dt class="col-sm-3">Upload Date:</dt>
            <dd class="col-sm-9">@Model.UploadDate.ToString("MM/dd/yyyy")</dd>

            <dt class="col-sm-3">File Size:</dt>
            <dd class="col-sm-9">@(Model.FileSize?.ToString("N0") ?? "0") KB</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>